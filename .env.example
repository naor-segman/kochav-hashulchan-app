# ── Supabase (admin area only) ────────────────────────────────────────────────
#
# Required only for the /admin/* routes.
# The customer app (/, /events/*) uses localStorage and never reads these.
#
# Setup:
#   1. Create a project at https://supabase.com
#   2. Copy Project URL and anon/public key from:
#      Project Settings → API → Project URL / Project API Keys
#   3. Create this file as .env.local (gitignored) with your real values:
#      cp .env.example .env.local
#
# Create the first admin user:
#   Run in Supabase SQL editor or Dashboard → Authentication → Users:
#   (any user you create manually can log in — no self-registration is exposed)
#
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Stripe (client-side — safe to expose) ─────────────────────────────────────
#
# STATUS: INACTIVE — payment UI not wired up yet.
# Add these when activating the billing phase.
#
# VITE_STRIPE_PUBLISHABLE_KEY   Stripe publishable key (pk_live_… or pk_test_…)
#                               Found in: Stripe Dashboard → Developers → API keys
#
VITE_STRIPE_PUBLISHABLE_KEY=

# ── Stripe (server-side only — Edge Function secrets) ─────────────────────────
#
# These values must NEVER be added to VITE_ variables.
# They are used exclusively by Supabase Edge Functions (Deno runtime).
#
# Set them via Supabase Dashboard → Edge Functions → Secrets, or:
#   supabase secrets set STRIPE_SECRET_KEY=sk_live_…
#
# STRIPE_SECRET_KEY             Stripe secret key (sk_live_… or sk_test_…)
#                               Found in: Stripe Dashboard → Developers → API keys
#
# STRIPE_WEBHOOK_SECRET         Webhook signing secret (whsec_…)
#                               Found in: Stripe Dashboard → Developers → Webhooks
#                               → select your endpoint → Signing secret
#                               Required to verify all incoming webhook events.
#
# STRIPE_PRO_PRICE_ID           Stripe Price ID for the Pro plan (price_…)
#                               Create in: Stripe Dashboard → Products → Pro → Add price
#
# STRIPE_ENTERPRISE_PRICE_ID    Stripe Price ID for the Enterprise plan (price_…)
#                               Create in: Stripe Dashboard → Products → Enterprise → Add price
#
# Example (do not commit real values):
#   STRIPE_SECRET_KEY=sk_test_…
#   STRIPE_WEBHOOK_SECRET=whsec_…
#   STRIPE_PRO_PRICE_ID=price_…
#   STRIPE_ENTERPRISE_PRICE_ID=price_…
