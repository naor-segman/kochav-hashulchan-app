# ── Supabase (admin area only) ────────────────────────────────────────────────
#
# Required only for the /admin/* routes.
# The customer app (/, /events/*) uses localStorage and never reads these.
#
# Setup:
#   1. Create a project at https://supabase.com
#   2. Copy Project URL and anon/public key from:
#      Project Settings → API → Project URL / Project API Keys
#   3. Create this file as .env.local (gitignored) with your real values:
#      cp .env.example .env.local
#
# Create the first admin user:
#   Run in Supabase SQL editor or Dashboard → Authentication → Users:
#   (any user you create manually can log in — no self-registration is exposed)
#
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
